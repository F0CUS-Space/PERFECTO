// Perfecto Cleaning Services — Database Schema (Version 1.0)
// Designed for V1.0 scope, with forward-compatible enums/relations for V1.5–V3.0.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CUSTOMER
  ADMIN
  // Future: CLEANER, COMMERCIAL
}

enum Frequency {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  BALANCE
  REFUND
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum GalleryItemType {
  CARD
  BEFORE_AFTER
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminAuditAction {
  BOOKING_STATUS_UPDATE
  SERVICE_CREATE
  SERVICE_UPDATE
  SERVICE_DELETE
  SERVICE_ADDONS_UPDATE
  ADDON_CREATE
  ADDON_UPDATE
  ADDON_DELETE
  APPLICATION_STATUS_UPDATE
  JOB_CREATE
  JOB_UPDATE
  JOB_DELETE
  USER_PROMOTE_ADMIN
  USER_DEMOTE_ADMIN
  GALLERY_CREATE
  GALLERY_UPDATE
  GALLERY_DELETE
  REVIEW_UPDATE
  REVIEW_DELETE
  SCHEDULE_BLOCK_CREATE
  SCHEDULE_BLOCK_DELETE
  PROMOTION_CREATE
  PROMOTION_UPDATE
  PROMOTION_DELETE
  PAYMENT_REFUND
  CHECKOUT_ATTEMPT_VOID
  ESTIMATE_CREATE
  ESTIMATE_SEND
  ESTIMATE_CANCEL
}

enum BookingOfferStatus {
  DRAFT
  SENT
  CONVERTED
  CANCELLED
  EXPIRED
}

enum PromotionDiscountType {
  FLAT
  PERCENTAGE
}

enum NotificationType {
  ADMIN_NEW_BOOKING
  ADMIN_BOOKING_CANCELLED
  ADMIN_BOOKING_RESCHEDULED
  CUSTOMER_SERVICE_UPDATE
  CUSTOMER_PROMOTION
  CUSTOMER_GENERAL_UPDATE
}

// ---------------------------------------------------------------------------
// Users & Auth (phone-first; email verification optional)
// ---------------------------------------------------------------------------

model User {
  id          String   @id @default(cuid())
  // Phone is the PRIMARY identifier (E.164). Verified via OTP before account creation.
  phone       String   @unique
  email       String?  @unique
  firstName   String?
  lastName    String?
  role        Role     @default(CUSTOMER)
  firebaseUid String?  @unique

  // Phone verification is required to create an account.
  phoneVerifiedAt DateTime?
  // Email verification is OPTIONAL — account works without it; UI shows a caution.
  emailVerifiedAt DateTime?

  bookings     Booking[]
  quotes       Quote[]
  bookingOffers BookingOffer[] @relation("BookingOfferCustomer")
  createdOffers BookingOffer[] @relation("BookingOfferCreatedBy")
  agreements   Agreement[]
  addresses    Address[]
  reviews      Review[]
  auditLogs    AdminAuditLog[]
  notifications Notification[]
  scheduleBlocks ScheduleBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// Saved addresses (single address used per booking in V1.0; relation enables reuse later).
model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  isDefault  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Service catalog (admin-managed)
// ---------------------------------------------------------------------------

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  longDescription String? @db.Text
  includes    String[] @default([])
  idealFor    String[] @default([])
  pricingNote String? @db.Text
  // Base price in cents to avoid floating point issues.
  basePrice   Int
  imageUrl    String?
  isActive    Boolean @default(true)
  isPopular   Boolean @default(false)
  sortOrder   Int     @default(0)

  quotes   Quote[]
  bookings Booking[]
  bookingOffers BookingOffer[]
  addOns   AddOnOnService[]
  promotions PromotionOnService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AddOn {
  id       String  @id @default(cuid())
  name     String
  // Price in cents.
  price    Int
  isActive Boolean @default(true)

  services   AddOnOnService[]
  quoteItems QuoteAddOn[]
}

// Which add-ons are available for which services.
model AddOnOnService {
  serviceId String
  addOnId   String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  addOn     AddOn   @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([serviceId, addOnId])
}

// ---------------------------------------------------------------------------
// Quote calculator
// ---------------------------------------------------------------------------

model Quote {
  id           String    @id @default(cuid())
  // Guests may generate a quote without an account.
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  serviceId    String
  service      Service   @relation(fields: [serviceId], references: [id])
  bedrooms     Int       @default(1)
  bathrooms    Int       @default(1)
  propertySize Int? // square feet (optional)
  hasPets      Boolean   @default(false)
  frequency    Frequency @default(ONE_TIME)

  addOns         QuoteAddOn[]
  // Computed estimate in cents + JSON breakdown for transparency.
  estimatedTotal Int
  breakdown      Json?

  promotionId            String?
  promotion              Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  promotionDiscountCents Int        @default(0)

  booking Booking?

  createdAt DateTime @default(now())

  @@index([userId])
}

model QuoteAddOn {
  quoteId String
  addOnId String
  quote   Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  addOn   AddOn @relation(fields: [addOnId], references: [id])

  @@id([quoteId, addOnId])
}

// ---------------------------------------------------------------------------
// Bookings
// ---------------------------------------------------------------------------

model Booking {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
  quoteId   String? @unique
  quote     Quote?  @relation(fields: [quoteId], references: [id])

  scheduledDate DateTime
  arrivalWindow String // e.g. "8:00 AM - 11:00 AM"
  status        BookingStatus @default(PENDING_PAYMENT)

  // Property snapshot (kept on the booking even if the saved address changes later)
  addressLine         String
  city                String
  postalCode          String
  bedrooms            Int
  bathrooms           Int
  propertySize        Int?
  hasPets             Boolean @default(false)
  petNotes            String?
  accessInfo          String?
  specialInstructions String?

  // Money in cents
  totalAmount   Int
  depositAmount Int // V1.0: full amount charged at booking (== totalAmount). Field name kept for schema stability; UI still labels this the "deposit".
  balanceAmount Int // V1.0: always 0 (no later balance collection)

  promotionId            String?
  promotion              Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  promotionTitle         String?
  promotionDiscountCents Int        @default(0)

  photos    PropertyPhoto[]
  payments  Payment[]
  invoice   Invoice?
  agreement Agreement?
  review    Review?
  bookingOffer BookingOffer?

  confirmationEmailSentAt DateTime?
  completionEmailSentAt   DateTime?
  rescheduledAt           DateTime?
  rescheduleCount         Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledDate])
}

// ---------------------------------------------------------------------------
// Staff-created estimates / pay invitations
// ---------------------------------------------------------------------------

model BookingOffer {
  id     String             @id @default(cuid())
  token  String             @unique
  status BookingOfferStatus @default(DRAFT)

  // Optional tagged existing customer account
  userId String?
  user   User?   @relation("BookingOfferCustomer", fields: [userId], references: [id], onDelete: SetNull)

  customerName  String
  customerEmail String?
  customerPhone String?

  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id])
  serviceName String

  // Total in cents; breakdown JSON holds service line + add-on / custom lines
  totalAmount Int
  breakdown   Json

  staffNotes        String? @db.Text
  messageToCustomer String? @db.Text

  createdById String
  createdBy   User     @relation("BookingOfferCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  sentAt      DateTime?
  expiresAt   DateTime

  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdById])
  @@index([expiresAt])
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  s3Key      String
  url        String
  uploadedAt DateTime @default(now())

  @@index([bookingId])
}

// ---------------------------------------------------------------------------
// Payments & Invoices
// ---------------------------------------------------------------------------

model Payment {
  id                String        @id @default(cuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider          String        @default("stripe")
  providerPaymentId String? // Stripe Checkout Session id (cs_...)
  // Stripe PaymentIntent id (pi_...) — captured on session completion so failed/refund
  // webhooks (which reference the PaymentIntent, not the session) can be matched.
  providerPaymentIntentId String?
  type              PaymentType   @default(DEPOSIT)
  amount            Int // cents
  status            PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerPaymentId])
  @@index([bookingId])
  @@index([providerPaymentId])
  @@index([providerPaymentIntentId])
}

model Invoice {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  number     String   @unique
  pdfUrl     String?
  amountDue  Int
  amountPaid Int      @default(0)
  issuedAt   DateTime @default(now())
}

// Monotonic per-year invoice sequence. Incremented atomically inside a transaction
// (row lock) so concurrent confirmations never collide on invoice numbers.
model InvoiceCounter {
  year Int @id
  seq  Int @default(0)
}

// Webhook idempotency + audit. Keyed by the provider event id so a redelivered
// event is processed at most once, and failures are observable for ops.
model ProcessedWebhookEvent {
  id        String   @id // provider event id (Stripe evt_...)
  provider  String   @default("stripe")
  type      String
  status    String   @default("PROCESSED") // PROCESSED | FAILED
  error     String?
  attempts  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
}

// Transactional outbox: durable side-effect intents written in the SAME transaction
// as the state change that triggers them. Drained by a worker (best-effort inline +
// a scheduled sweep), so post-commit side effects survive process crashes.
model OutboxEvent {
  id          String    @id @default(cuid())
  type        String // e.g. "BOOKING_CONFIRMED"
  payload     Json
  status      String    @default("PENDING") // PENDING | PROCESSING | PROCESSED | FAILED
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Electronic agreements (immutable once signed)
// ---------------------------------------------------------------------------

model Agreement {
  id                  String  @id @default(cuid())
  userId              String
  user                User    @relation(fields: [userId], references: [id])
  bookingId           String  @unique
  booking             Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  acceptedTerms       Boolean @default(false)
  acceptedCancellation Boolean @default(false)
  acceptedLiability   Boolean @default(false)
  signatureName       String
  ipAddress           String?
  signedAt            DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Recruitment
// ---------------------------------------------------------------------------

model JobPosting {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  type          String
  location      String
  compensation  String
  summary       String
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model JobApplication {
  id        String            @id @default(cuid())
  fullName  String
  email     String
  phone     String
  position  String
  resumeS3Key String?
  resumeUrl String?
  coverNote String?
  status    ApplicationStatus @default(SUBMITTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ---------------------------------------------------------------------------
// Gallery (marketing)
// ---------------------------------------------------------------------------

model GalleryItem {
  id        String          @id @default(cuid())
  type      GalleryItemType
  title     String
  category  String
  imageUrl  String?
  beforeUrl String?
  afterUrl  String?
  sortOrder Int             @default(0)
  isActive  Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ---------------------------------------------------------------------------
// Customer reviews (testimonials)
// ---------------------------------------------------------------------------

model Review {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  bookingId String       @unique
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating    Int
  body      String
  featured  Boolean      @default(false)
  status    ReviewStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, featured])
}

// ---------------------------------------------------------------------------
// Schedule blocks (admin-managed unavailable dates/times)
// ---------------------------------------------------------------------------

model ScheduleBlock {
  id          String   @id @default(cuid())
  blockDate   DateTime
  allDay      Boolean  @default(true)
  startTime   String?
  endTime     String?
  reason      String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([blockDate])
}

// ---------------------------------------------------------------------------
// Promotions (admin-managed; applied when claimed during booking)
// ---------------------------------------------------------------------------

model Promotion {
  id            String                 @id @default(cuid())
  title         String
  description   String
  imageUrl      String?
  discountType  PromotionDiscountType
  // FLAT: cents off. PERCENTAGE: whole percent (e.g. 15 = 15% off).
  discountValue Int
  isActive      Boolean                @default(true)

  services PromotionOnService[]
  quotes   Quote[]
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PromotionOnService {
  promotionId String
  serviceId   String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([promotionId, serviceId])
}

// ---------------------------------------------------------------------------
// Admin audit log
// ---------------------------------------------------------------------------

model AdminAuditLog {
  id         String           @id @default(cuid())
  actorId    String
  actor      User             @relation(fields: [actorId], references: [id], onDelete: Restrict)
  action     AdminAuditAction
  entityType String
  entityId   String?
  summary    String
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
}

// ---------------------------------------------------------------------------
// In-app notifications
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}
