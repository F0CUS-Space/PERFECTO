# =============================================================================
# PERFECTO CLEANING SERVICES — Environment Variables (Version 1.0)
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
# Public base URL of the app (used for metadata, emails, Stripe redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "true" in local dev to enable Firebase test-phone UI (OTP 123123) and skip reCAPTCHA verification.
NEXT_PUBLIC_AUTH_DEV_MODE=true
AUTH_DEV_MODE=true

# -----------------------------------------------------------------------------
# Database — PostgreSQL (self-hosted via Docker on EC2)
# Local dev with docker-compose uses host "localhost"; the app container uses "db".
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# NOTE: the password here MUST match POSTGRES_PASSWORD below.
# Host port defaults to 5544 (see POSTGRES_HOST_PORT) to avoid clashing with a
# native Postgres that may already be running on 5432.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://perfecto:perfecto@localhost:5544/perfecto?schema=public"

# Used by docker-compose to initialize the Postgres container.
POSTGRES_USER=perfecto
POSTGRES_PASSWORD=perfecto
POSTGRES_DB=perfecto
# Host port mapped to the container's 5432 (change if 5544 is also taken).
POSTGRES_HOST_PORT=5544
# Host port for the Docker app (container still listens on 3000 internally).
APP_HOST_PORT=3002

# -----------------------------------------------------------------------------
# Firebase Authentication — WEB (client SDK). All must be NEXT_PUBLIC_*.
# Get these from: Firebase Console > Project Settings > General > Your apps (Web).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyCFq9ustBiKH4z-POjGj8ht4Tue1tQnX4I"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="perfecto-8033b.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="perfecto-8033b"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="perfecto-8033b.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="871798968052"
NEXT_PUBLIC_FIREBASE_APP_ID="1:871798968052:web:29d04996cde14fc3cf98a1"

# -----------------------------------------------------------------------------
# Firebase Admin — SERVER (verifies ID tokens). From a Service Account JSON:
# Firebase Console > Project Settings > Service accounts > Generate new private key.
# Keep the private key on ONE line with literal \n for newlines, wrapped in quotes.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Stripe — deposit payments. From: Stripe Dashboard > Developers > API keys.
# Webhook secret: Developers > Webhooks > (your endpoint) > Signing secret,
# or `stripe listen` for local development.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# AWS S3 — property photo & resume uploads (presigned URLs).
# Create an IAM user with PutObject/GetObject on the bucket, OR attach an IAM role to EC2
# (production) and omit the access keys — the SDK uses the instance role automatically.
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Email — Resend (transactional email). From: resend.com > API Keys.
# EMAIL_FROM must be a verified sender/domain in Resend.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Perfecto <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Seed (optional) — initial admin account created by `npm run db:seed`.
# -----------------------------------------------------------------------------
SEED_ADMIN_PHONE=+10000000000
SEED_ADMIN_EMAIL=admin@perfecto.local
